# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

# If JAVA_HOME is not set, try to find it.
if [ -z "$JAVA_HOME" ] ; then
  if [ -r /etc/gentoo-release ] ; then
    JAVA_HOME=$(java -XshowSettings:vm -version 2>&1 | awk '/java.home/{print $3}')
  else
    JAVA_HOME_CANDIDATES="/usr/lib/jvm/java-17-openjdk /usr/lib/jvm/java-17 /usr/lib/jvm/temurin-17 /Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home"
    for candidate in $JAVA_HOME_CANDIDATES; do
      if [ -d "$candidate" ]; then
        JAVA_HOME=$candidate
        break
      fi
    done
  fi
fi

JAVA_CMD="java"
if [ -n "$JAVA_HOME" ] ; then
  JAVA_CMD="$JAVA_HOME/bin/java"
fi

# Determine the project base dir
SCRIPT="$0"
while [ -h "$SCRIPT" ] ; do
  ls=$(ls -ld "$SCRIPT")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    SCRIPT="$link"
  else
    SCRIPT="$(dirname "$SCRIPT")/$link"
  fi
done
MAVEN_PROJECTBASEDIR="$(dirname "$SCRIPT")"
cd "$MAVEN_PROJECTBASEDIR" || exit

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

# Download or use the local wrapper jar
if [ -r "$MAVEN_WRAPPER_JAR" ]; then
  :
else
  DOWNLOAD_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2)
  JAR_URL=$(grep wrapperUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2)
  echo "Downloading Maven Wrapper from: $JAR_URL"
  if command -v wget > /dev/null; then
    wget -q -O "$MAVEN_WRAPPER_JAR" "$JAR_URL" || { echo "wget failed"; exit 1; }
  elif command -v curl > /dev/null; then
    curl -o "$MAVEN_WRAPPER_JAR" -fsSL "$JAR_URL" || { echo "curl failed"; exit 1; }
  else
    echo "Neither wget nor curl is available. Cannot download Maven Wrapper."
    exit 1
  fi
fi

exec "$JAVA_CMD" \
  -classpath "$MAVEN_WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
